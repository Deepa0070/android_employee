<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/holo_orange_light"
            android:padding="15dp"
            android:layout_marginBottom="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Leave Request"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request leaves from Common Pool"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- ELIGIBILITY STATUS (THIS WAS MISSING!) -->
        <TextView
            android:id="@+id/tvEligibilityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking eligibility..."
            android:textSize="16sp"
            android:padding="15dp"
            android:background="@android:color/white"
            android:layout_marginBottom="15dp"
            android:gravity="center"/>

        <!-- Pool Availability -->
        <TextView
            android:id="@+id/tvPoolAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading pool availability..."
            android:textSize="16sp"
            android:textColor="#2196F3"
            android:padding="15dp"
            android:background="@android:color/white"
            android:layout_marginBottom="20dp"
            android:gravity="center"/>

        <!-- Form -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Leave Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leave Type *"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etReason"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g. Medical Emergency"
                    android:padding="10dp" />

                <Spinner
                    android:id="@+id/spLeaveType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/edit_text_background"/>

                <!-- From Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From Date *"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etFromDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="DD/MM/YYYY"
                    android:inputType="none"
                    android:focusable="false"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/edit_text_background"
                    android:padding="10dp"
                    tools:ignore="TextFields" />

                <!-- To Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To Date *"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etToDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="DD/MM/YYYY"
                    android:inputType="none"
                    android:focusable="false"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/edit_text_background"
                    android:padding="10dp"
                    tools:ignore="TextFields" />

                <!-- Reason -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reason for Leave *"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:layout_marginBottom="5dp"/>

                <!-- Emergency Details -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Details *"
                    android:textSize="16sp"
                    android:textColor="#333"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/etEmergencyDetails"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Explain the emergency situation"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/edit_text_background"
                    android:padding="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Submit Emergency Request"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@android:color/holo_orange_dark"
            android:textColor="@android:color/white"
            android:layout_marginBottom="10dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>